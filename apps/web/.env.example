# NutriCore — apps/web env vars
# Copie para .env.local (NÃO commitar) e preencha com valores reais
#
# ⚠️  WINDOWS: após `vercel env pull .env.local`, rode:
#       ./scripts/fix-env-bom.sh
# para remover BOM UTF-8 que o Vercel CLI insere nos valores (causa o
# erro "Can't reach database server at <truncated-host>" no Prisma).
# Detalhes: vercel/vercel#7349

# ============================================================
# Supabase (S2a)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role: NUNCA expor ao client. Usado apenas em workers + setup.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Database URL para Prisma (Supabase Connection Pooler — porta 6543)
DATABASE_URL=postgresql://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct URL para Prisma migrate (porta 5432, sem pooler)
DIRECT_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres

# ============================================================
# Email (Lock 9 — Resend primário S2-S4, depois AWS SES)
# ============================================================
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_YOUR_KEY
# Default: onboarding@resend.dev (válido em dev sem verificar domínio).
# Em produção, troque por noreply@seudominio.com APÓS verificar o domínio
# no Resend.
RESEND_FROM_ADDRESS=onboarding@resend.dev

# AWS SES (será habilitado após sair de sandbox)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ============================================================
# Upstash (Redis + QStash)
# ============================================================
UPSTASH_REDIS_REST_URL=https://YOUR.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR-TOKEN

QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=YOUR-TOKEN
QSTASH_CURRENT_SIGNING_KEY=YOUR-KEY
QSTASH_NEXT_SIGNING_KEY=YOUR-KEY

# ============================================================
# Sentry + PostHog (já podem ficar vazios em dev)
# ============================================================
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# Sanity (apps/marketing principalmente, mas web pode consumir)
# ============================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=p61sxa53
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# ============================================================
# Anonimização (Lock 4/13) — em produção, vem do Supabase Vault
# ============================================================
# Estes ficam APENAS no Vault em produção. Em dev local, definir aqui:
# ANON_SALT=dev-only-salt-do-not-use-in-prod
# ANON_HMAC_KEY=dev-only-hmac-key-do-not-use-in-prod
